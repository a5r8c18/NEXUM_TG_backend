# ============================================
# NEXUM TG - Backend Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=nexum_db
DB_SYNCHRONIZE=false          # true ONLY in development; NEVER in production
DB_LOGGING=false              # true to see SQL queries in console
DB_POOL_MAX=20                # max connections in pool
DB_POOL_MIN=5                 # min connections in pool

# --- Authentication (JWT) ---
JWT_SECRET=generate-a-strong-random-secret-at-least-32-chars
# JWT_EXPIRES_IN=24h          # (future: token expiration)

# --- Server ---
PORT=3001
NODE_ENV=development          # development | production

# --- CORS ---
# For production, specify exact origins (comma-separated)
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
# OR specify single frontend URL
# FRONTEND_URL=https://yourdomain.com
# In development, allows localhost:* automatically

# --- Email (future) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your_smtp_password
# SMTP_FROM=NEXUM TG <noreply@example.com>

# --- Redis (future) ---
# REDIS_HOST=localhost
# REDIS_PORT=6379
